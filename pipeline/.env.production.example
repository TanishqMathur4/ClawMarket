# GOAT Network Mainnet Configuration
NETWORK_ENV=mainnet
GOAT_RPC_URL=https://rpc.goat.network
GATEWAY_PRIVATE_KEY=your_private_key_here

# Mainnet Contract Addresses
CONTRACT_ADDRESS=0x...  # From Teammate 1
TUSDIC_ADDRESS=0x...    # Mainnet tUSDC

# Logging
LOG_FILE_PATH=../shared/log.json

# Optional
POLLING_INTERVAL=2
MAX_RETRIES=3
