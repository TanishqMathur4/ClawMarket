# Production environment variables for ClawUp deployment.
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to the repo.

# GOAT Network mainnet RPC
GOAT_RPC_URL=https://rpc.mainnet.goat.network

# Private key of the gateway wallet (holds gas only — no user funds)
GATEWAY_PRIVATE_KEY=0xyour_gateway_private_key

# ClawCourtEscrow contract address on GOAT mainnet (from Teammate 1 after mainnet deploy)
CONTRACT_ADDRESS=0xto_be_filled_after_mainnet_deploy

# tUSDC token contract on GOAT mainnet
TUSDC_ADDRESS=0xto_be_filled_after_mainnet_deploy

# ERC-8004 IdentityRegistry on GOAT mainnet (from Teammate 1)
IDENTITY_REGISTRY_ADDRESS=0xto_be_filled_after_mainnet_deploy

# Public HTTPS URL of this agent's /agent.json — used as the ERC-8004 token URI
# This is what 8004scan.io and brokers will fetch to discover the agent.
AGENT_JSON_URI=https://pipeline.clawcourt.xyz/agent.json

# Path where the pipeline writes the shared log (must be readable by Teammate 4's dashboard)
LOG_FILE_PATH=../shared/log.json

# Leave false in production
MOCK_MODE=false
