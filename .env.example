# ============================================================
# ClawCourt — Unified Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── T1 / T2: Chain ──────────────────────────────────────────
# GOAT Network Testnet RPC endpoint
GOAT_RPC_URL=https://rpc.testnet3.goat.network

# Deployer / gateway wallet private key (no 0x prefix needed)
PRIVATE_KEY=your_private_key_here

# tUSDC contract address on GOAT Testnet3 (chain 48816)
# Deployed by GOATNetwork/goat-testnet-usd — 18 decimals
TUSDC_ADDRESS=0xFCA5846c86dC8Df1B1e21447649A08a18B667B92

# Block explorer API key (if required by GOAT explorer)
GOAT_EXPLORER_API_KEY=

# ── T2: Pipeline ────────────────────────────────────────────
# Gateway wallet private key (signs releaseFunds / refundFunds)
# Can be the same as PRIVATE_KEY above
GATEWAY_PRIVATE_KEY=your_private_key_here

# Deployed escrow contract address (filled after T1 deploys)
CONTRACT_ADDRESS=0x_FILL_AFTER_T1_DEPLOYS

# Path to the shared transaction log (relative to project root)
LOG_FILE_PATH=./shared/log.json

# ERC-8004 IdentityRegistry address on GOAT Network (for agent registration)
IDENTITY_REGISTRY_ADDRESS=0x_FILL_FROM_GOAT_DOCS

# Public HTTPS URL of this agent's /agent.json (ERC-8004 token URI)
AGENT_JSON_URI=https://your-deployment-url/agent.json

# Set to "true" to run pipeline with mock events instead of live chain polling
MOCK_MODE=false

# Seconds between mock events when MOCK_MODE=true (default: 4)
MOCK_EVENT_INTERVAL=4

# ── T3: AI Referee ──────────────────────────────────────────
# Anthropic API key for Claude Haiku referee calls
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Log level for referee module
LOG_LEVEL=INFO
